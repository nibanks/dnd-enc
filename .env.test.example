# Test Environment Configuration
# Copy this file to .env.test and fill in with your test credentials

# D&D Beyond Cookies (for testing real API integration)
# Get these from your browser's Developer Tools > Application > Cookies
# Visit https://www.dndbeyond.com and copy the cookie values

DNDBEYOND_COOKIE_COBALTID=your_CobaltId_value_here
DNDBEYOND_COOKIE_COBALTAFF=your_CobaltAff_value_here
DNDBEYOND_COOKIE_COBALTAT=your_CobaltAT_value_here

# Test D&D Beyond URLs (use real monster/character URLs from D&D Beyond)
TEST_MONSTER_URL=monsters/17140-goblin
TEST_CHARACTER_URL=12345678

# Optional: Skip real API tests if credentials not available
SKIP_DNDBEYOND_TESTS=false
